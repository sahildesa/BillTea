# BillTea Mobile App (Expo) Environment Configuration
# API endpoint for the backend server
# Replace <IP_ADDR> with your computer's local network IPv4 address (e.g. 192.168.1.100)
# This is required for physical devices running Expo Go to connect to the backend API.
EXPO_PUBLIC_API_URL=http://<IP_ADDR>:5000/api/v1
