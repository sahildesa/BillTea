generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  MANAGER
  STAFF
}

enum SignatureType {
  TEXT
  IMAGE
}

model Company {
  id          String   @id @default(uuid())
  name        String
  logo        String   @default("")
  identifiers Json     @default("[]")
  isActive    Boolean  @default(true)
  createdById String?
  createdBy   User?    @relation("CompanyCreator", fields: [createdById], references: [id])
  branches    Branch[]
  customers   Customer[]
  products            Product[]
  expenses            Expense[]
  expenseCategories   ExpenseCategory[]
  users               User[]   @relation("CompanyUsers")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("companies")
}

model User {
  id               String         @id @default(uuid())
  fullName         String
  phoneNumber      String         @unique
  email            String         @unique
  password         String
  profilePicture   String         @default("")
  role             UserRole       @default(STAFF)
  isActive         Boolean        @default(true)
  companyId        String?
  company          Company?       @relation("CompanyUsers", fields: [companyId], references: [id])
  createdById      String?
  createdBy        User?          @relation("UserCreator", fields: [createdById], references: [id])
  createdUsers     User[]         @relation("UserCreator")
  companiesCreated Company[]      @relation("CompanyCreator")
  customersCreated Customer[]     @relation("UserCreatedCustomers")
  productsCreated          Product[]         @relation("UserCreatedProducts")
  expensesCreated          Expense[]         @relation("UserCreatedExpenses")
  expenseCategoriesCreated ExpenseCategory[] @relation("UserCreatedExpenseCategories")
  branches                 Branch[]          @relation("UserBranches")
  refreshTokens    RefreshToken[]
  lastLoginAt      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@map("users")
}

model Branch {
  id             String        @id @default(uuid())
  companyId      String
  company        Company       @relation(fields: [companyId], references: [id])
  name           String
  isMainBranch   Boolean       @default(false)
  address        String        @default("")
  city           String        @default("")
  state          String        @default("")
  pincode        String        @default("")
  phone          String        @default("")
  email          String        @default("")
  bankName       String        @default("")
  accountNumber  String        @default("")
  ifscCode       String        @default("")
  upiId          String        @default("")
  signatureType  SignatureType @default(TEXT)
  signatureValue String        @default("")
  tax            Int           @default(0)
  isActive       Boolean       @default(true)
  customers      Customer[]
  products       Product[]
  expenses       Expense[]
  users          User[]        @relation("UserBranches")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([companyId, name])
  @@map("branches")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model Customer {
  id                  String   @id @default(uuid())
  companyId           String
  company             Company  @relation(fields: [companyId], references: [id])
  branchId            String
  branch              Branch   @relation(fields: [branchId], references: [id])
  
  customerName        String
  companyName         String   @default("")
  email               String   @default("")
  mobileNumber        String
  businessLabel       String   @default("")
  businessLabelValue  String   @default("")
  address             String   @default("")
  otherInfo           String   @default("")
  
  isActive            Boolean  @default(true)
  createdById         String?
  createdBy           User?    @relation("UserCreatedCustomers", fields: [createdById], references: [id])
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("customers")
}

model Product {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  branchId    String
  branch      Branch   @relation(fields: [branchId], references: [id])
  
  name        String
  description String   @default("")
  image       String   @default("")
  price       Float
  hsnNumber   String   @default("")
  skuNumber   String   @default("")
  
  isActive    Boolean  @default(true)
  createdById String?
  createdBy   User?    @relation("UserCreatedProducts", fields: [createdById], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("products")
}

model Expense {
  id            String   @id @default(uuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  branchId      String
  branch        Branch   @relation(fields: [branchId], references: [id])
  
  amount        Float
  categoryId    String?
  category      ExpenseCategory? @relation(fields: [categoryId], references: [id])
  paymentMethod String
  note          String   @default("")
  date          DateTime
  attachment    String   @default("")
  
  createdById   String?
  createdBy     User?    @relation("UserCreatedExpenses", fields: [createdById], references: [id])
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("expenses")
}

model ExpenseCategory {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  
  name        String
  
  createdById String?
  createdBy   User?    @relation("UserCreatedExpenseCategories", fields: [createdById], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  expenses    Expense[]

  @@unique([companyId, name])
  @@map("expense_categories")
}
