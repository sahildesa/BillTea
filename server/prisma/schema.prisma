generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  OWNER
  MANAGER
}

enum PlanRank {
  TRIAL
  BRONZE
  SILVER
  GOLD
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  CANCELLED
}

enum SubPaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum NotificationType {
  SUBSCRIPTION_PURCHASED
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  SUBSCRIPTION_EXPIRING
  SUBSCRIPTION_EXPIRED
  PLAN_UPGRADED
  PLAN_DOWNGRADED
}

enum QuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  EXPIRED
}

enum InvoiceStatus {
  UNPAID
  PARTIAL
  PAID
  OVERDUE
}

enum PaymentMethod {
  CASH
  UPI
  BANK_TRANSFER
  CHEQUE
}

model Company {
  id                   String                @id @default(uuid())
  name                 String
  logo                 String                @default("")
  identifiers          Json                  @default("[]")
  isActive             Boolean               @default(true)
  createdById          String?
  createdBy            User?                 @relation("CompanyCreator", fields: [createdById], references: [id])
  branches             Branch[]
  customers            Customer[]
  products             Product[]
  expenses             Expense[]
  expenseCategories    ExpenseCategory[]
  quotations           Quotation[]
  invoices             Invoice[]
  users                User[]                @relation("CompanyUsers")
  subscription         CompanySubscription?
  usage                CompanyUsage?
  subscriptionPayments SubscriptionPayment[]
  notifications        Notification[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@map("companies")
}

model User {
  id                       String            @id @default(uuid())
  fullName                 String
  phoneNumber              String            @unique
  email                    String            @unique
  password                 String
  profilePicture           String            @default("")
  role                     UserRole          @default(MANAGER)
  isActive                 Boolean           @default(true)
  companyId                String?
  company                  Company?          @relation("CompanyUsers", fields: [companyId], references: [id])
  createdById              String?
  createdBy                User?             @relation("UserCreator", fields: [createdById], references: [id])
  createdUsers             User[]            @relation("UserCreator")
  companiesCreated         Company[]         @relation("CompanyCreator")
  customersCreated         Customer[]        @relation("UserCreatedCustomers")
  productsCreated          Product[]         @relation("UserCreatedProducts")
  expensesCreated          Expense[]         @relation("UserCreatedExpenses")
  expenseCategoriesCreated ExpenseCategory[] @relation("UserCreatedExpenseCategories")
  quotationsCreated        Quotation[]       @relation("UserCreatedQuotations")
  quotationsUpdated        Quotation[]       @relation("UserUpdatedQuotations")
  invoicesCreated          Invoice[]         @relation("UserCreatedInvoices")
  invoicesUpdated          Invoice[]         @relation("UserUpdatedInvoices")
  branches                 Branch[]          @relation("UserBranches")
  refreshTokens            RefreshToken[]
  lastLoginAt              DateTime?
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt

  @@map("users")
}

model Branch {
  id                String            @id @default(uuid())
  companyId         String
  company           Company           @relation(fields: [companyId], references: [id])
  name              String
  isMainBranch      Boolean           @default(false)
  address           String            @default("")
  city              String            @default("")
  state             String            @default("")
  pincode           String            @default("")
  phone             String            @default("")
  email             String            @default("")
  bankName          String            @default("")
  accountNumber     String            @default("")
  ifscCode          String            @default("")
  upiId             String            @default("")
  signatureValue    String            @default("")
  tax               Int               @default(0)
  taxLabel          String            @default("")
  quotationTheme    String            @default("INDUX_MODERN")
  themeColor        String            @default("#0ea5e9")
  isActive          Boolean           @default(true)
  customers         Customer[]
  products          Product[]
  expenses          Expense[]
  expenseCategories ExpenseCategory[]
  quotations        Quotation[]
  invoices          Invoice[]
  users             User[]            @relation("UserBranches")
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@unique([companyId, name])
  @@map("branches")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model Customer {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])
  branchId  String
  branch    Branch  @relation(fields: [branchId], references: [id])

  customerName       String
  companyName        String @default("")
  email              String @default("")
  mobileNumber       String
  businessLabel      String @default("")
  businessLabelValue String @default("")
  address            String @default("")
  otherInfo          String @default("")

  isActive    Boolean @default(true)
  createdById String?
  createdBy   User?   @relation("UserCreatedCustomers", fields: [createdById], references: [id])

  quotations Quotation[]
  invoices   Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("customers")
}

model Product {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])
  branchId  String
  branch    Branch  @relation(fields: [branchId], references: [id])

  name        String
  description String @default("")
  image       String @default("")
  price       Float
  hsnNumber   String @default("")
  skuNumber   String @default("")

  isActive    Boolean @default(true)
  createdById String?
  createdBy   User?   @relation("UserCreatedProducts", fields: [createdById], references: [id])

  quotationItems QuotationItem[]
  invoiceItems   InvoiceItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("products")
}

model Expense {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])
  branchId  String
  branch    Branch  @relation(fields: [branchId], references: [id])

  amount        Float
  categoryId    String?
  category      ExpenseCategory? @relation(fields: [categoryId], references: [id])
  paymentMethod String
  note          String           @default("")
  date          DateTime
  attachment    String           @default("")

  createdById String?
  createdBy   User?   @relation("UserCreatedExpenses", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("expenses")
}

model ExpenseCategory {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])
  branchId  String
  branch    Branch  @relation(fields: [branchId], references: [id])

  name String

  createdById String?
  createdBy   User?   @relation("UserCreatedExpenseCategories", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  expenses Expense[]

  @@unique([branchId, name])
  @@map("expense_categories")
}

model Quotation {
  id              String @id @default(uuid())
  quotationNumber String
  sequenceNumber  Int    @default(0)

  companyId        String
  company          Company  @relation(fields: [companyId], references: [id])
  branchId         String
  branch           Branch   @relation(fields: [branchId], references: [id])
  customerId       String
  customer         Customer @relation(fields: [customerId], references: [id])
  customerSnapshot Json     @default("{}")

  status        QuotationStatus @default(DRAFT)
  quotationDate DateTime
  expiryDate    DateTime

  billingAddressSnapshot  Json
  shippingAddressSnapshot Json
  shippingSameAsBilling   Boolean @default(true)

  discountConfiguration Json
  taxConfiguration      Json

  subtotal       Float @default(0)
  discountAmount Float @default(0)
  taxAmount      Float @default(0)
  grandTotal     Float @default(0)

  notes              String    @default("")
  followUpDate       DateTime?
  termsAndConditions Json      @default("{}")

  createdById String?
  createdBy   User?   @relation("UserCreatedQuotations", fields: [createdById], references: [id])
  updatedById String?
  updatedBy   User?   @relation("UserUpdatedQuotations", fields: [updatedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items       QuotationItem[]
  attachments QuotationAttachment[]

  @@unique([branchId, sequenceNumber])
  @@map("quotations")
}

model QuotationItem {
  id          String    @id @default(uuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)

  productSnapshot Json

  originalPrice       Float
  originalDescription String @default("")
  originalImage       String @default("")

  editedPrice       Float
  editedDescription String @default("")
  editedImage       String @default("")

  quantity Int   @default(1)
  discount Json  @default("{}")
  tax      Float @default(0)

  subtotal       Float @default(0)
  discountAmount Float @default(0)
  taxAmount      Float @default(0)
  total          Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("quotation_items")
}

model QuotationAttachment {
  id          String    @id @default(uuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  fileName    String
  fileSize    Int
  mimeType    String
  storagePath String

  uploadedAt DateTime @default(now())

  @@map("quotation_attachments")
}

model Invoice {
  id             String @id @default(uuid())
  invoiceNumber  String
  sequenceNumber Int    @default(0)

  companyId        String
  company          Company  @relation(fields: [companyId], references: [id])
  branchId         String
  branch           Branch   @relation(fields: [branchId], references: [id])
  customerId       String
  customer         Customer @relation(fields: [customerId], references: [id])
  customerSnapshot Json     @default("{}")

  status      InvoiceStatus @default(UNPAID)
  invoiceDate DateTime
  dueDate     DateTime

  billingAddressSnapshot  Json
  shippingAddressSnapshot Json
  shippingSameAsBilling   Boolean @default(true)

  discountConfiguration Json
  taxConfiguration      Json

  subtotal       Float @default(0)
  discountAmount Float @default(0)
  taxAmount      Float @default(0)
  grandTotal     Float @default(0)

  amountPaid Float @default(0)
  amountDue  Float @default(0)

  notes              String @default("")
  termsAndConditions Json   @default("{}")

  linkedQuotationId String?

  createdById String?
  createdBy   User?   @relation("UserCreatedInvoices", fields: [createdById], references: [id])
  updatedById String?
  updatedBy   User?   @relation("UserUpdatedInvoices", fields: [updatedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items       InvoiceItem[]
  attachments InvoiceAttachment[]
  payments    InvoicePayment[]

  @@unique([branchId, sequenceNumber])
  @@map("invoices")
}

model InvoiceItem {
  id        String   @id @default(uuid())
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  productSnapshot Json

  originalPrice       Float
  originalDescription String @default("")
  originalImage       String @default("")

  editedPrice       Float
  editedDescription String @default("")
  editedImage       String @default("")

  quantity Int   @default(1)
  discount Json  @default("{}")
  tax      Float @default(0)

  subtotal       Float @default(0)
  discountAmount Float @default(0)
  taxAmount      Float @default(0)
  total          Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("invoice_items")
}

model InvoiceAttachment {
  id        String  @id @default(uuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  fileName    String
  fileSize    Int
  mimeType    String
  storagePath String

  uploadedAt DateTime @default(now())

  @@map("invoice_attachments")
}

model InvoicePayment {
  id        String  @id @default(uuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  amount        Float
  method        PaymentMethod
  date          DateTime
  note          String        @default("")
  attachmentUrl String        @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("invoice_payments")
}

// ─── Subscription Management ───────────────────────────────────────

model SubscriptionPlan {
  id            String   @id @default(uuid())
  name          String
  rank          PlanRank
  description   String   @default("")
  displayOrder  Int      @unique
  isActive      Boolean  @default(true)
  isDeleted     Boolean  @default(false)
  isRecommended Boolean  @default(false)

  // Pricing
  price        Float
  billingCycle BillingCycle

  // Usage Limits (0 = Unlimited)
  quotationLimit       Int @default(0)
  invoiceLimit         Int @default(0)
  customerLimit        Int @default(0)
  productLimit         Int @default(0)
  branchLimit          Int @default(0)
  staffLimit           Int @default(0)
  whatsappMessageLimit Int @default(0)

  // Feature Permissions
  customQuotationThemes Boolean @default(false)
  customInvoiceThemes   Boolean @default(false)
  whatsappIntegration   Boolean @default(false)

  // Relations
  subscriptions CompanySubscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("subscription_plans")
}

model CompanySubscription {
  id        String           @id @default(uuid())
  companyId String           @unique
  company   Company          @relation(fields: [companyId], references: [id])
  planId    String
  plan      SubscriptionPlan @relation(fields: [planId], references: [id])

  status     SubscriptionStatus @default(TRIAL)
  startDate  DateTime           @default(now())
  expiryDate DateTime

  paymentId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("company_subscriptions")
}

model SubscriptionPayment {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  planId   String
  amount   Float
  currency String @default("INR")

  razorpayOrderId   String @default("")
  razorpayPaymentId String @default("")
  razorpaySignature String @default("")

  status      SubPaymentStatus @default(PENDING)
  paymentDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("subscription_payments")
}

model CompanyUsage {
  id        String  @id @default(uuid())
  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id])

  quotationsUsed       Int @default(0)
  invoicesUsed         Int @default(0)
  customersUsed        Int @default(0)
  productsUsed         Int @default(0)
  whatsappMessagesSent Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("company_usage")
}

model Notification {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  type    NotificationType
  title   String
  message String
  isRead  Boolean          @default(false)

  createdAt DateTime @default(now())

  @@map("notifications")
}
